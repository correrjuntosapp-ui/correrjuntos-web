{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/patrocinadores",
      "destination": "/inversores",
      "permanent": true
    },
    {
      "source": "/sponsors",
      "destination": "/inversores",
      "permanent": true
    },
    {
      "source": "/contacto",
      "destination": "/sobre-nosotros#contacto",
      "permanent": false
    },
    {
      "source": "/contact",
      "destination": "/sobre-nosotros#contacto",
      "permanent": false
    },
    {
      "source": "/anunciate",
      "destination": "/inversores",
      "permanent": true
    },
    {
      "source": "/media-kit",
      "destination": "/inversores#media-kit",
      "permanent": false
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "correrjuntos.com"
        }
      ],
      "destination": "https://www.correrjuntos.com/:path",
      "permanent": true
    }
  ]
}
