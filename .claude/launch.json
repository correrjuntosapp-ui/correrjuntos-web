{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/serve/build/main.js", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "expo-web",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/expo/bin/cli", "start", "--web", "--port", "8081"],
      "port": 8081,
      "cwd": "correr-juntos-app"
    }
  ]
}
