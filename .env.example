# CorrerJuntos — Environment Variables
# Copy to .env.local for local development
# Set in Vercel dashboard for production

# Supabase (server-side only — used by API routes)
SUPABASE_SERVICE_KEY=           # Service role key (sb_secret_...)

# Stripe (server-side only — used by /api/stripe-webhook.js)
STRIPE_SECRET_KEY=              # sk_live_... (production) or sk_test_... (development)
STRIPE_WEBHOOK_SECRET=          # whsec_... (from Stripe Dashboard → Webhooks)

# Stripe client-side key (NOT an env var — set directly in js/app.js)
# Production: replace 'pk_live_REPLACE_WITH_YOUR_LIVE_KEY' in js/app.js
# The code auto-detects hostname (correrjuntos.com = live, else = test)

# Brevo (Newsletter — used by /api/brevo-subscribe.js)
BREVO_API_KEY=                  # xkeysib-...
BREVO_DOI_TEMPLATE_ID=3
BREVO_WELCOME_TEMPLATE_ES=1
BREVO_WELCOME_TEMPLATE_EN=4

# IndexNow (used by /api/indexnow.js)
INDEXNOW_SECRET=                # Bearer token for authorization

# Vercel (auto-set by Vercel CLI)
# VERCEL_OIDC_TOKEN=           # JWT for OIDC auth (managed by Vercel)
